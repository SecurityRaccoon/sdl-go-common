{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.sdl.dev/aggregated-result.schema.json",
  "title": "AggregatedResult",
  "type": "object",
  "required": [
    "scan_id",
    "organization_id",
    "correlation_id",
    "status",
    "total_repositories",
    "completed_repositories",
    "total_findings",
    "by_severity",
    "findings",
    "repositories",
    "started_at",
    "completed_at"
  ],
  "definitions": {
    "finding": {
      "type": "object",
      "required": ["id", "rule_id", "severity", "file", "line", "end_line", "message", "tool"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "rule_id": {"type": "string", "minLength": 1},
        "severity": {
          "type": "string",
          "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
        },
        "category": {"type": "string"},
        "file": {"type": "string", "minLength": 1},
        "line": {"type": "integer", "minimum": 0},
        "end_line": {"type": "integer", "minimum": 0},
        "column": {"type": "integer", "minimum": 0},
        "message": {"type": "string", "minLength": 1},
        "snippet": {"type": "string"},
        "tool": {"type": "string", "minLength": 1},
        "confidence": {"type": "string"},
        "metadata": {"type": "object"},
        "references": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "repository": {"type": "string"},
        "branch": {"type": "string"},
        "commit_hash": {"type": "string"},
        "fingerprint": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "scan_id": {"type": "string", "minLength": 1},
    "organization_id": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["completed", "partial_complete", "failed"]
    },
    "total_repositories": {"type": "integer", "minimum": 0},
    "completed_repositories": {"type": "integer", "minimum": 0},
    "total_findings": {"type": "integer", "minimum": 0},
    "by_severity": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "total_duration_seconds": {"type": "integer", "minimum": 0},
    "total_files_scanned": {"type": "integer", "minimum": 0},
    "total_lines_scanned": {"type": "integer", "minimum": 0},
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    },
    "repositories": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "missing_repositories": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
