{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.sdl.dev/scan-completed-event.schema.json",
  "title": "ScanCompletedEvent",
  "type": "object",
  "required": ["scan_id", "scanner_type", "status", "findings", "completed_at", "correlation_id"],
  "definitions": {
    "finding": {
      "type": "object",
      "required": ["id", "rule_id", "severity", "file", "line", "end_line", "message", "tool"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "rule_id": {"type": "string", "minLength": 1},
        "severity": {
          "type": "string",
          "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
        },
        "category": {"type": "string"},
        "file": {"type": "string", "minLength": 1},
        "line": {"type": "integer", "minimum": 0},
        "end_line": {"type": "integer", "minimum": 0},
        "column": {"type": "integer", "minimum": 0},
        "message": {"type": "string", "minLength": 1},
        "snippet": {"type": "string"},
        "tool": {"type": "string", "minLength": 1},
        "confidence": {"type": "string"},
        "metadata": {"type": "object"},
        "references": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "repository": {"type": "string"},
        "branch": {"type": "string"},
        "commit_hash": {"type": "string"},
        "fingerprint": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "job_id": {"type": "string", "minLength": 1},
    "scan_id": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "scanner_type": {"type": "string", "minLength": 1},
    "repository": {
      "type": "object",
      "properties": {
        "url": {"type": "string"},
        "ref": {"type": "string"}
      },
      "additionalProperties": true
    },
    "target": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["completed", "partial_complete", "failed"]
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "duration_seconds": {"type": "integer", "minimum": 0},
        "files_scanned": {"type": "integer", "minimum": 0},
        "lines_scanned": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "completed_at": {"type": "string", "format": "date-time"}
  },
  "anyOf": [
    {"required": ["repository"]},
    {"required": ["target"]}
  ],
  "additionalProperties": true
}
