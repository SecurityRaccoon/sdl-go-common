#!/bin/sh
set -e
cd "$(git rev-parse --show-toplevel)"
echo "Running pre-commit checks..."
if [ -n "$(gofmt -l .)" ]; then
    echo "ERROR: Files need formatting. Run 'make lint-fix'"
    gofmt -l .
    exit 1
fi
go vet ./... 2>&1 || {
    echo "ERROR: go vet failed. Fix issues before committing."
    exit 1
}
echo "Pre-commit checks passed."
