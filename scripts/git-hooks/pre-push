#!/bin/sh

set -eu

cd "$(git rev-parse --show-toplevel)"

has_target() {
    make -n "$1" >/dev/null 2>&1
}

run_required_target() {
    target="$1"
    printf 'Running %s...\n' "$target"
    make "$target"
}

run_optional_target() {
    target="$1"
    if has_target "$target"; then
        printf 'Running %s...\n' "$target"
        make "$target"
    fi
}

printf 'Running pre-push verification...\n'
run_required_target lint
run_optional_target type-check
run_optional_target typecheck
run_required_target test
printf 'Pre-push verification passed.\n'
